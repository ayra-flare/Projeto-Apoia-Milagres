{
  "name": "Demand",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo da demanda/necessidade"
    },
    "type": {
      "type": "string",
      "enum": [
        "alimento",
        "roupa",
        "recurso",
        "voluntario",
        "outro"
      ],
      "default": "alimento",
      "description": "Tipo da demanda"
    },
    "urgency": {
      "type": "string",
      "enum": [
        "baixa",
        "media",
        "alta",
        "urgente"
      ],
      "default": "media",
      "description": "N\u00edvel de urg\u00eancia da demanda"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada da necessidade"
    },
    "quantity": {
      "type": "string",
      "description": "Quantidade necess\u00e1ria (ex: '50 kg', '30 unidades')"
    },
    "deadline": {
      "type": "string",
      "format": "date",
      "description": "Prazo para atendimento"
    },
    "ong_id": {
      "type": "string",
      "description": "ID da ONG que publicou a demanda"
    },
    "ong_name": {
      "type": "string",
      "description": "Nome da ONG (denormalizado para exibi\u00e7\u00e3o)"
    },
    "status": {
      "type": "string",
      "enum": [
        "ativa",
        "atendida",
        "encerrada"
      ],
      "default": "ativa",
      "description": "Status atual da demanda"
    }
  },
  "required": [
    "title",
    "description"
  ]
}